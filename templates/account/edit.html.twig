{% extends 'storefront/base.html.twig' %}

{% block title %}Modifier mon profil - E-Shop{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-bold text-slate-800 dark:text-white">Modifier mon profil</h1>
        <a href="{{ path('app_account') }}" class="text-slate-500 hover:text-indigo-600 dark:hover:text-indigo-400 font-medium transition-colors">
            ← Retour au compte
        </a>
    </div>

    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 p-8">
        {{ form_start(form) }}
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
            <div>
                {{ form_label(form.firstname, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2'}}) }}
                {{ form_widget(form.firstname, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-600 dark:bg-slate-700 dark:text-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 dark:focus:ring-indigo-900 transition-all outline-none'}}) }}
                {{ form_errors(form.firstname, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
            </div>
            
            <div>
                {{ form_label(form.lastname, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2'}}) }}
                {{ form_widget(form.lastname, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-600 dark:bg-slate-700 dark:text-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 dark:focus:ring-indigo-900 transition-all outline-none'}}) }}
                {{ form_errors(form.lastname, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
            </div>
        </div>

        <div class="mb-6">
            {{ form_label(form.email, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2'}}) }}
            {{ form_widget(form.email, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-600 bg-slate-50 dark:bg-slate-900/50 text-slate-500 dark:text-slate-400 cursor-not-allowed'}}) }}
            <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">L'adresse email ne peut pas être modifiée.</p>
        </div>

        <div class="mb-6">
            {{ form_label(form.profilePictureFile, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2'}}) }}
            <div class="flex items-center gap-4">
                {% if app.user.profilePicturePath %}
                    <img src="{{ app.user.profilePicturePath }}" alt="Photo actuelle" class="w-16 h-16 rounded-full object-cover">
                {% else %}
                    <div class="w-16 h-16 bg-slate-100 dark:bg-slate-700 rounded-full flex items-center justify-center text-slate-400">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                    </div>
                {% endif %}
                <div class="flex-1">
                    {{ form_widget(form.profilePictureFile, {'attr': {'class': 'block w-full text-sm text-slate-500 dark:text-slate-400 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 dark:file:bg-indigo-900/30 file:text-indigo-700 dark:file:text-indigo-300 hover:file:bg-indigo-100 dark:hover:file:bg-indigo-900/50 transition-colors'}}) }}
                </div>
            </div>
            {{ form_errors(form.profilePictureFile, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
        </div>

        <div class="mb-6">
            {{ form_label(form.phone, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2'}}) }}
            {{ form_widget(form.phone, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-600 dark:bg-slate-700 dark:text-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 dark:focus:ring-indigo-900 transition-all outline-none'}}) }}
            {{ form_errors(form.phone, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
        </div>

        <div class="mb-8">
            {{ form_label(form.address, null, {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2'}}) }}
            {{ form_widget(form.address, {'attr': {'class': 'w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-600 dark:bg-slate-700 dark:text-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 dark:focus:ring-indigo-900 transition-all outline-none min-h-[100px]'}}) }}
            {{ form_errors(form.address, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
        </div>

        <div class="flex justify-end pt-6 border-t border-slate-100 dark:border-slate-700">
            <button type="submit" class="px-8 py-3 bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-bold rounded-xl shadow-lg shadow-indigo-500/25 hover:shadow-indigo-500/40 transition-all hover:-translate-y-1">
                Enregistrer les modifications
            </button>
        </div>
        
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
