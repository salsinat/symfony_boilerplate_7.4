{% extends 'storefront/base.html.twig' %}

{% block title %}Mon compte - E-Shop{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold text-slate-800 dark:text-white mb-8">Mon compte</h1>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Profile Card -->
        <div class="md:col-span-2 bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 p-6">
            <div class="flex items-center gap-6 mb-6">
                {% if app.user.profilePicturePath %}
                    <img src="{{ app.user.profilePicturePath }}" alt="{{ app.user.firstname }}" class="w-20 h-20 rounded-full object-cover shadow-md border-2 border-white dark:border-slate-700">
                {% else %}
                    <div class="w-20 h-20 bg-gradient-to-br from-indigo-500 to-purple-500 rounded-full flex items-center justify-center text-white text-2xl font-bold shadow-md">
                        {{ app.user.firstname|first|upper }}{{ app.user.lastname|first|upper }}
                    </div>
                {% endif %}
                
                <div class="flex-1">
                    <h2 class="text-xl font-bold text-slate-800 dark:text-white">{{ app.user.firstname }} {{ app.user.lastname }}</h2>
                    <p class="text-slate-500 dark:text-slate-400">{{ app.user.email }}</p>
                    {% if not app.user.verified %}
                        <span class="inline-block mt-2 px-3 py-1 bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 text-xs font-medium rounded-lg">
                            Email non vérifié
                        </span>
                    {% else %}
                        <span class="inline-block mt-2 px-3 py-1 bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 text-xs font-medium rounded-lg">
                            Email vérifié
                        </span>
                    {% endif %}
                </div>
                
                <a href="{{ path('app_account_edit') }}" class="p-2 text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors" title="Modifier le profil">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                </a>
            </div>

            {% if app.user.address %}
                <div class="border-t border-slate-100 dark:border-slate-700 pt-6">
                    <h3 class="font-semibold text-slate-700 dark:text-slate-300 mb-2">Adresse de livraison</h3>
                    <p class="text-slate-600 dark:text-slate-400">{{ app.user.address|nl2br }}</p>
                </div>
            {% endif %}

            {% if app.user.phone %}
                <div class="border-t border-slate-100 dark:border-slate-700 pt-6 mt-6">
                    <h3 class="font-semibold text-slate-700 dark:text-slate-300 mb-2">Téléphone</h3>
                    <p class="text-slate-600 dark:text-slate-400">{{ app.user.phone }}</p>
                </div>
            {% endif %}
        </div>

        <!-- Quick Links -->
        <div class="space-y-4">
            <a href="{{ path('app_account_orders') }}" class="block bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 p-6 hover:shadow-md transition-all group">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-indigo-100 dark:bg-indigo-900/30 rounded-xl flex items-center justify-center text-indigo-600 dark:text-indigo-400 group-hover:bg-indigo-600 group-hover:text-white transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                        </svg>
                    </div>
                    <div>
                        <div class="font-semibold text-slate-800 dark:text-white">Mes commandes</div>
                        <div class="text-sm text-slate-500 dark:text-slate-400">Historique des achats</div>
                    </div>
                </div>
            </a>

            <a href="{{ path('app_storefront_catalog') }}" class="block bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 p-6 hover:shadow-md transition-all group">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-emerald-100 dark:bg-emerald-900/30 rounded-xl flex items-center justify-center text-emerald-600 dark:text-emerald-400 group-hover:bg-emerald-600 group-hover:text-white transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                        </svg>
                    </div>
                    <div>
                        <div class="font-semibold text-slate-800 dark:text-white">Catalogue</div>
                        <div class="text-sm text-slate-500 dark:text-slate-400">Continuer mes achats</div>
                    </div>
                </div>
            </a>
            
            {% if is_granted('ROLE_MANAGER') %}
             <a href="{{ path('app_dashboard') }}" class="block bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 p-6 hover:shadow-md transition-all group">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/30 rounded-xl flex items-center justify-center text-purple-600 dark:text-purple-400 group-hover:bg-purple-600 group-hover:text-white transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
                        </svg>
                    </div>
                    <div>
                        <div class="font-semibold text-slate-800 dark:text-white">Dashboard</div>
                        <div class="text-sm text-slate-500 dark:text-slate-400">Administration</div>
                    </div>
                </div>
            </a>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
