{% extends 'base.html.twig' %}

{% block title %}Nouvel Utilisateur{% endblock %}
{% block page_title %}Créer un Utilisateur{% endblock %}
{% block page_subtitle %}Ajouter un nouveau compte{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto">
    <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-xl border border-slate-200/50 overflow-hidden">
        <div class="px-8 py-6 border-b border-slate-200/50 bg-gradient-to-r from-purple-50 to-pink-50">
            <h2 class="text-xl font-bold text-slate-800">Informations de l'utilisateur</h2>
            <p class="text-sm text-slate-500 mt-1">Remplissez les champs ci-dessous</p>
        </div>
        
        <div class="p-8">
            {{ include('user/_form.html.twig', {'button_label': 'Créer l\'utilisateur'}) }}
        </div>
    </div>
</div>
{% endblock %}
