{% extends 'base.html.twig' %}

{% block title %}Modifier {{ user.firstname }}{% endblock %}
{% block page_title %}Modifier l'Utilisateur{% endblock %}
{% block page_subtitle %}{{ user.email }}{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto">
    <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-xl border border-slate-200/50 overflow-hidden">
        <div class="px-8 py-6 border-b border-slate-200/50 bg-gradient-to-r from-purple-50 to-pink-50">
            <div class="flex items-center">
                <div class="w-12 h-12 bg-gradient-to-br from-purple-500 to-pink-500 rounded-full flex items-center justify-center text-white font-bold text-lg shadow-md mr-4">
                    {{ user.firstname|first|upper }}{{ user.lastname|first|upper }}
                </div>
                <div>
                    <h2 class="text-xl font-bold text-slate-800">{{ user.firstname }} {{ user.lastname }}</h2>
                    <p class="text-sm text-slate-500">ID: #{{ user.id }}</p>
                </div>
            </div>
        </div>
        
        <div class="p-8">
            {{ include('user/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
        </div>
    </div>

    <!-- Delete Section -->
    <div class="mt-6 bg-red-50/50 backdrop-blur-sm rounded-2xl border border-red-200/50 p-6">
        <h3 class="text-lg font-bold text-red-800 mb-2">Zone de danger</h3>
        <p class="text-sm text-red-600 mb-4">La suppression est irréversible. Toutes les données seront perdues.</p>
        {{ include('user/_delete_form.html.twig') }}
    </div>
</div>
{% endblock %}
