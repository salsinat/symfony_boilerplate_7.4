{{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
            {{ form_label(form.email, 'Email', {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 mb-2'}}) }}
            {{ form_widget(form.email, {'attr': {'class': 'w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition-colors bg-white/50'}}) }}
            {{ form_errors(form.email) }}
        </div>

        <div>
            {{ form_label(form.password, 'Mot de passe', {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 mb-2'}}) }}
            {{ form_widget(form.password, {'attr': {'class': 'w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition-colors bg-white/50', 'placeholder': '••••••••'}}) }}
            {{ form_errors(form.password) }}
        </div>

        <div>
            {{ form_label(form.firstname, 'Prénom', {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 mb-2'}}) }}
            {{ form_widget(form.firstname, {'attr': {'class': 'w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition-colors bg-white/50'}}) }}
            {{ form_errors(form.firstname) }}
        </div>

        <div>
            {{ form_label(form.lastname, 'Nom', {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 mb-2'}}) }}
            {{ form_widget(form.lastname, {'attr': {'class': 'w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition-colors bg-white/50'}}) }}
            {{ form_errors(form.lastname) }}
        </div>
    </div>

    <div>
        {{ form_label(form.roles, 'Rôles', {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 mb-3'}}) }}
        <div class="flex flex-wrap gap-4">
            {% for role in form.roles %}
                <label class="inline-flex items-center px-4 py-2 border border-slate-300 rounded-xl cursor-pointer hover:bg-purple-50 transition-colors has-[:checked]:bg-purple-100 has-[:checked]:border-purple-500">
                    {{ form_widget(role, {'attr': {'class': 'w-4 h-4 text-purple-600 border-slate-300 rounded focus:ring-purple-500 mr-2'}}) }}
                    <span class="text-sm font-medium text-slate-700">{{ role.vars.label }}</span>
                </label>
            {% endfor %}
        </div>
        {{ form_errors(form.roles) }}
    </div>

    <div class="flex items-center justify-end pt-6 border-t border-slate-200">
        <a href="{{ path('app_user_index') }}" class="px-6 py-2.5 text-slate-600 hover:text-slate-800 font-medium mr-4">Annuler</a>
        <button type="submit" class="inline-flex items-center px-6 py-2.5 bg-gradient-to-r from-purple-600 to-pink-600 text-white font-semibold rounded-xl shadow-lg shadow-purple-500/25 hover:shadow-purple-500/40 transition-all hover:-translate-y-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            {{ button_label|default('Enregistrer') }}
        </button>
    </div>
{{ form_end(form) }}
