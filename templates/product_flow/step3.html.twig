{% extends 'base.html.twig' %}

{% block title %}Nouveau Produit - Étape 3{% endblock %}
{% block page_title %}Nouveau Produit{% endblock %}
{% block page_subtitle %}Assistant de création multi-étapes{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto">
    <!-- Step Indicator -->
    <div class="mb-8">
        <div class="flex items-center justify-center">
            <div class="flex items-center">
                <div class="w-10 h-10 bg-emerald-500 rounded-full flex items-center justify-center text-white font-bold">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                </div>
                <div class="w-20 h-1 bg-emerald-500"></div>
            </div>
            <div class="flex items-center">
                <div class="w-10 h-10 bg-emerald-500 rounded-full flex items-center justify-center text-white font-bold">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                </div>
                <div class="w-20 h-1 bg-emerald-500"></div>
            </div>
            <div class="flex items-center">
                <div class="w-10 h-10 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-full flex items-center justify-center text-white font-bold shadow-lg shadow-blue-500/30">3</div>
                <div class="w-20 h-1 bg-slate-200"></div>
            </div>
            <div>
                <div class="w-10 h-10 bg-slate-200 rounded-full flex items-center justify-center text-slate-400 font-bold">4</div>
            </div>
        </div>
        <div class="flex justify-center mt-4 space-x-12 text-xs">
            <span class="text-emerald-600">Type ✓</span>
            <span class="text-emerald-600">Détails ✓</span>
            <span class="text-blue-600 font-semibold">Spécifiques</span>
            <span class="text-slate-400">Confirmation</span>
        </div>
    </div>

    <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-xl border border-slate-200/50 overflow-hidden">
        <div class="px-8 py-6 border-b border-slate-200/50 {{ type == 'physical' ? 'bg-gradient-to-r from-emerald-50 to-teal-50' : 'bg-gradient-to-r from-violet-50 to-purple-50' }}">
            <div class="flex items-center">
                {% if type == 'physical' %}
                    <div class="w-12 h-12 bg-gradient-to-br from-emerald-500 to-teal-500 rounded-xl flex items-center justify-center text-white shadow-md mr-4">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                        </svg>
                    </div>
                    <div>
                        <h2 class="text-xl font-bold text-slate-800">Produit Physique</h2>
                        <p class="text-sm text-slate-500">Informations de logistique</p>
                    </div>
                {% else %}
                    <div class="w-12 h-12 bg-gradient-to-br from-violet-500 to-purple-500 rounded-xl flex items-center justify-center text-white shadow-md mr-4">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                    </div>
                    <div>
                        <h2 class="text-xl font-bold text-slate-800">Produit Numérique</h2>
                        <p class="text-sm text-slate-500">Informations de licence</p>
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="p-8">
            {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}
                
                {% if type == 'physical' %}
                    <div>
                        {{ form_label(form.weight, 'Poids du produit', {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 mb-2'}}) }}
                        <div class="relative">
                            {{ form_widget(form.weight, {'attr': {'class': 'w-full px-4 py-3 pr-12 border border-slate-300 rounded-xl focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-colors bg-white/50', 'placeholder': '0.5'}}) }}
                            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 font-semibold">kg</span>
                        </div>
                        <p class="mt-2 text-sm text-slate-500">Utilisé pour le calcul des frais de livraison</p>
                        {{ form_errors(form.weight) }}
                    </div>
                {% else %}
                    <div>
                        {{ form_label(form.licenceKey, 'Clé de licence', {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 mb-2'}}) }}
                        {{ form_widget(form.licenceKey, {'attr': {'class': 'w-full px-4 py-3 font-mono border border-slate-300 rounded-xl focus:ring-2 focus:ring-violet-500 focus:border-violet-500 transition-colors bg-white/50', 'placeholder': 'XXXX-XXXX-XXXX-XXXX'}}) }}
                        <p class="mt-2 text-sm text-slate-500">Clé unique ou lien de téléchargement sécurisé</p>
                        {{ form_errors(form.licenceKey) }}
                    </div>
                {% endif %}
                
                <div class="flex justify-between pt-6 border-t border-slate-200">
                    <a href="{{ path('product_flow_details') }}" class="inline-flex items-center px-4 py-2 text-slate-600 hover:text-slate-800 font-medium">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                        </svg>
                        Retour
                    </a>
                    {{ form_widget(form.next, {'attr': {'class': 'inline-flex items-center px-6 py-3 bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-semibold rounded-xl shadow-lg shadow-blue-500/25 hover:shadow-blue-500/40 transition-all hover:-translate-y-0.5'}}) }}
                </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
