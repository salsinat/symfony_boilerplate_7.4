{% extends 'base.html.twig' %}

{% block title %}Modifier {{ product.name }}{% endblock %}
{% block page_title %}Modifier le Produit{% endblock %}
{% block page_subtitle %}{{ product.name }}{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto">
    <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-xl border border-slate-200/50 overflow-hidden">
        <div class="px-8 py-6 border-b border-slate-200/50 bg-gradient-to-r from-emerald-50 to-teal-50">
            <div class="flex items-center">
                <div class="w-12 h-12 {{ product.type == 'digital' ? 'bg-gradient-to-br from-violet-500 to-purple-500' : 'bg-gradient-to-br from-emerald-500 to-teal-500' }} rounded-xl flex items-center justify-center text-white shadow-md mr-4">
                    {% if product.type == 'digital' %}
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                    {% else %}
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                        </svg>
                    {% endif %}
                </div>
                <div>
                    <h2 class="text-xl font-bold text-slate-800">{{ product.name }}</h2>
                    <p class="text-sm text-slate-500">ID: #{{ product.id }}</p>
                </div>
            </div>
        </div>
        
        <div class="p-8">
            {{ include('product/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
        </div>
    </div>

    <!-- Delete Section -->
    <div class="mt-6 bg-red-50/50 backdrop-blur-sm rounded-2xl border border-red-200/50 p-6">
        <h3 class="text-lg font-bold text-red-800 mb-2">Zone de danger</h3>
        <p class="text-sm text-red-600 mb-4">La suppression est irréversible.</p>
        {{ include('product/_delete_form.html.twig') }}
    </div>
</div>
{% endblock %}
