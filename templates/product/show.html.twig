{% extends 'base.html.twig' %}

{% block title %}{{ product.name }}{% endblock %}
{% block page_title %}Détails Produit{% endblock %}
{% block page_subtitle %}{{ product.slug }}{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto">
    <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-xl border border-slate-200/50 overflow-hidden">
        <div class="flex flex-col lg:flex-row">
            <!-- Left: Image/Icon -->
            <div class="lg:w-1/3 {{ product.type == 'digital' ? 'bg-gradient-to-br from-violet-500 to-purple-600' : 'bg-gradient-to-br from-emerald-500 to-teal-600' }} p-8 flex flex-col items-center justify-center text-white">
                <div class="w-24 h-24 bg-white/20 backdrop-blur rounded-2xl flex items-center justify-center mb-6">
                    {% if product.type == 'digital' %}
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                    {% else %}
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                        </svg>
                    {% endif %}
                </div>
                <span class="px-4 py-2 bg-white/20 backdrop-blur rounded-xl text-sm font-semibold mb-4">
                    {{ product.type == 'digital' ? 'Produit Numérique' : 'Produit Physique' }}
                </span>
                <div class="text-4xl font-bold mb-2">{{ (product.price / 100)|number_format(2, ',', ' ') }} €</div>
                <div class="px-4 py-2 rounded-full text-sm font-semibold {{ product.stock > 0 ? 'bg-white/20' : 'bg-red-500/50' }}">
                    {{ product.stock > 0 ? product.stock ~ ' en stock' : 'Rupture de stock' }}
                </div>
            </div>

            <!-- Right: Details -->
            <div class="lg:w-2/3 p-8">
                <h1 class="text-3xl font-bold text-slate-800 mb-2">{{ product.name }}</h1>
                <p class="text-sm text-slate-400 font-mono mb-6">ID: #{{ product.id }}</p>

                <div class="prose max-w-none text-slate-600 mb-8 bg-slate-50 rounded-xl p-6">
                    {{ product.description|nl2br }}
                </div>

                <!-- Product specific info -->
                <div class="grid grid-cols-2 gap-4 mb-8">
                    {% if product.type == 'physical' and product.weight %}
                        <div class="bg-slate-50 rounded-xl p-4">
                            <p class="text-sm text-slate-500">Poids</p>
                            <p class="text-lg font-bold text-slate-800">{{ product.weight }} kg</p>
                        </div>
                    {% endif %}
                    {% if product.type == 'digital' and product.licenceKey %}
                        <div class="bg-violet-50 rounded-xl p-4 col-span-2">
                            <p class="text-sm text-violet-600">Clé de licence</p>
                            <p class="text-lg font-mono font-bold text-violet-800">{{ product.licenceKey }}</p>
                        </div>
                    {% endif %}
                </div>

                <!-- Actions -->
                <div class="flex items-center gap-4 pt-6 border-t border-slate-200">
                    <a href="{{ path('app_product_index') }}" class="inline-flex items-center text-slate-600 hover:text-slate-800 font-medium">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                        </svg>
                        Retour
                    </a>
                    <a href="{{ path('app_product_edit', {'id': product.id}) }}" class="inline-flex items-center px-5 py-2.5 bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                        </svg>
                        Modifier
                    </a>
                    {{ include('product/_delete_form.html.twig') }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
