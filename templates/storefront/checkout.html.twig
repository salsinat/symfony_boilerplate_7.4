{% extends 'storefront/base.html.twig' %}

{% block title %}Passer commande - E-Shop{% endblock %}

{% block body %}
<h1 class="text-3xl font-bold text-slate-800 mb-8">Passer commande</h1>

<form action="{{ path('app_checkout_confirm') }}" method="post">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Shipping Info -->
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
                <h2 class="text-xl font-bold text-slate-800 mb-6">Informations de livraison</h2>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-2">Prénom</label>
                        <input type="text" value="{{ user.firstname }}" readonly
                               class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-slate-700">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-2">Nom</label>
                        <input type="text" value="{{ user.lastname }}" readonly
                               class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-slate-700">
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-semibold text-slate-700 mb-2">Email</label>
                        <input type="email" value="{{ user.email }}" readonly
                               class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-slate-700">
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-semibold text-slate-700 mb-2">Adresse de livraison</label>
                        <textarea name="address" rows="3" required
                                  placeholder="Entrez votre adresse complète..."
                                  class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">{{ user.address }}</textarea>
                    </div>
                </div>
            </div>

            <!-- Order Items -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
                <h2 class="text-xl font-bold text-slate-800 mb-6">Articles commandés</h2>
                
                <div class="space-y-4">
                    {% for id, item in cart %}
                        <div class="flex items-center gap-4 py-4 {{ not loop.last ? 'border-b border-slate-100' : '' }}">
                            <div class="w-16 h-16 bg-gradient-to-br from-slate-100 to-slate-200 rounded-xl flex items-center justify-center flex-shrink-0">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                                </svg>
                            </div>
                            <div class="flex-1">
                                <div class="font-semibold text-slate-800">{{ item.name }}</div>
                                <div class="text-sm text-slate-500">Qté: {{ item.quantity }}</div>
                            </div>
                            <div class="font-bold text-slate-800">{{ ((item.price * item.quantity) / 100)|number_format(2, ',', ' ') }} €</div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>

        <!-- Summary -->
        <div class="lg:col-span-1">
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 sticky top-24">
                <h2 class="text-xl font-bold text-slate-800 mb-6">Total</h2>

                <div class="space-y-4 mb-6">
                    <div class="flex justify-between text-slate-600">
                        <span>Sous-total</span>
                        <span>{{ (total / 100)|number_format(2, ',', ' ') }} €</span>
                    </div>
                    <div class="flex justify-between text-slate-600">
                        <span>Livraison</span>
                        <span class="text-emerald-600">Gratuite</span>
                    </div>
                </div>

                <div class="border-t border-slate-200 pt-4 mb-6">
                    <div class="flex justify-between text-xl font-bold text-slate-800">
                        <span>Total</span>
                        <span>{{ (total / 100)|number_format(2, ',', ' ') }} €</span>
                    </div>
                </div>

                <button type="submit" class="w-full inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-emerald-600 to-teal-600 text-white font-bold rounded-xl shadow-lg shadow-emerald-500/30 hover:shadow-emerald-500/50 transition-all hover:-translate-y-1">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    Confirmer la commande
                </button>

                <a href="{{ path('app_cart') }}" class="block text-center mt-4 text-slate-500 hover:text-indigo-600 transition-colors">
                    Retour au panier
                </a>
            </div>
        </div>
    </div>
</form>
{% endblock %}
