{% extends 'storefront/base.html.twig' %}

{% block title %}{{ product.name }} - E-Shop{% endblock %}

{% block body %}
<div class="mb-6">
    <a href="{{ path('app_storefront_catalog') }}" class="inline-flex items-center text-slate-500 hover:text-indigo-600 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Retour au catalogue
    </a>
</div>

<div class="bg-white rounded-2xl shadow-xl border border-slate-100 overflow-hidden">
    <div class="grid grid-cols-1 lg:grid-cols-2">
        <!-- Image -->
        <div class="aspect-square {{ product.type == 'digital' ? 'bg-gradient-to-br from-violet-500 to-purple-600' : 'bg-gradient-to-br from-slate-100 to-slate-200' }} flex items-center justify-center">
            {% if product.type == 'digital' %}
                <svg xmlns="http://www.w3.org/2000/svg" class="h-32 w-32 text-white/80" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
            {% else %}
                <svg xmlns="http://www.w3.org/2000/svg" class="h-32 w-32 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                </svg>
            {% endif %}
        </div>

        <!-- Details -->
        <div class="p-8 lg:p-12">
            <div class="mb-4">
                <span class="inline-block px-3 py-1 {{ product.type == 'digital' ? 'bg-violet-100 text-violet-700' : 'bg-emerald-100 text-emerald-700' }} rounded-lg text-sm font-medium">
                    {{ product.type == 'digital' ? 'Produit Numérique' : 'Produit Physique' }}
                </span>
            </div>

            <h1 class="text-3xl font-bold text-slate-800 mb-4">{{ product.name }}</h1>
            
            <div class="text-4xl font-bold text-indigo-600 mb-6">
                {{ (product.price / 100)|number_format(2, ',', ' ') }} €
            </div>

            <div class="prose text-slate-600 mb-8">
                {{ product.description|nl2br }}
            </div>

            {% if product.type == 'physical' and product.weight %}
                <div class="mb-6 text-sm text-slate-500">
                    <span class="font-medium">Poids:</span> {{ product.weight }} kg
                </div>
            {% endif %}

            <!-- Stock Status -->
            <div class="mb-8">
                {% if product.stock > 10 %}
                    <div class="flex items-center text-emerald-600">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        <span class="font-medium">En stock</span>
                    </div>
                {% elseif product.stock > 0 %}
                    <div class="flex items-center text-amber-600">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                        <span class="font-medium">Plus que {{ product.stock }} en stock</span>
                    </div>
                {% else %}
                    <div class="flex items-center text-red-600">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                        <span class="font-medium">Rupture de stock</span>
                    </div>
                {% endif %}
            </div>

            <!-- Add to Cart -->
            {% if product.stock > 0 %}
                <form action="{{ path('app_cart_add', {'id': product.id}) }}" method="post">
                    <button type="submit" class="w-full inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-bold rounded-xl shadow-lg shadow-indigo-500/30 hover:shadow-indigo-500/50 transition-all hover:-translate-y-1">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                        </svg>
                        Ajouter au panier
                    </button>
                </form>
            {% else %}
                <button disabled class="w-full inline-flex items-center justify-center px-8 py-4 bg-slate-300 text-slate-500 font-bold rounded-xl cursor-not-allowed">
                    Indisponible
                </button>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
