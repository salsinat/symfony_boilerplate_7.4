{% extends 'storefront/base.html.twig' %}

{% block title %}Commande confirmée - E-Shop{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto text-center">
    <!-- Success Icon -->
    <div class="w-24 h-24 bg-gradient-to-br from-emerald-500 to-teal-500 rounded-full flex items-center justify-center mx-auto mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
    </div>

    <h1 class="text-3xl font-bold text-slate-800 mb-4">Merci pour votre commande !</h1>
    <p class="text-slate-500 mb-8">Votre commande n° <span class="font-bold text-indigo-600">#{{ order.id }}</span> a été confirmée.</p>

    <!-- Order Details -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-8 text-left mb-8">
        <h2 class="text-xl font-bold text-slate-800 mb-6">Détails de la commande</h2>

        <div class="space-y-4 mb-6">
            {% for item in order.items %}
                <div class="flex justify-between items-center py-3 {{ not loop.last ? 'border-b border-slate-100' : '' }}">
                    <div>
                        <div class="font-semibold text-slate-800">{{ item.product.name }}</div>
                        <div class="text-sm text-slate-500">Qté: {{ item.quantity }}</div>
                    </div>
                    <div class="font-bold text-slate-800">{{ (item.subtotal / 100)|number_format(2, ',', ' ') }} €</div>
                </div>
            {% endfor %}
        </div>

        <div class="border-t border-slate-200 pt-4">
            <div class="flex justify-between text-xl font-bold text-slate-800">
                <span>Total</span>
                <span>{{ (order.total / 100)|number_format(2, ',', ' ') }} €</span>
            </div>
        </div>

        {% if order.shippingAddress %}
            <div class="mt-6 pt-6 border-t border-slate-200">
                <h3 class="font-semibold text-slate-700 mb-2">Adresse de livraison</h3>
                <p class="text-slate-600">{{ order.shippingAddress|nl2br }}</p>
            </div>
        {% endif %}
    </div>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="{{ path('app_account_orders') }}" class="inline-flex items-center justify-center px-6 py-3 bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-semibold rounded-xl shadow-lg">
            Voir mes commandes
        </a>
        <a href="{{ path('app_storefront_catalog') }}" class="inline-flex items-center justify-center px-6 py-3 bg-white text-slate-700 font-semibold rounded-xl border border-slate-200 hover:bg-slate-50">
            Continuer mes achats
        </a>
    </div>
</div>
{% endblock %}
