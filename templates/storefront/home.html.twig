{% extends 'storefront/base.html.twig' %}

{% block title %}Accueil - E-Shop{% endblock %}

{% block body %}
<!-- Hero Section with animated gradient -->
<div class="relative overflow-hidden rounded-3xl mb-16" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);">
    <!-- Animated blobs -->
    <div class="absolute inset-0 overflow-hidden">
        <div class="absolute -top-1/2 -left-1/4 w-96 h-96 bg-white/10 rounded-full blur-3xl animate-pulse"></div>
        <div class="absolute -bottom-1/2 -right-1/4 w-96 h-96 bg-pink-300/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
        <div class="absolute top-1/4 right-1/4 w-64 h-64 bg-yellow-300/10 rounded-full blur-2xl animate-pulse" style="animation-delay: 2s;"></div>
    </div>
    
    <div class="relative z-10 px-8 py-20 md:px-16 md:py-28">
        <div class="max-w-3xl">
            <span class="inline-block px-4 py-2 bg-white/20 backdrop-blur-sm rounded-full text-white/90 text-sm font-medium mb-6">
                ✨ Bienvenue sur notre boutique
            </span>
            
            <h1 class="text-4xl md:text-6xl lg:text-7xl font-black text-white mb-6 leading-[1.1]">
                Découvrez nos
                <span class="relative inline-block">
                    <span class="relative z-10" style="background: linear-gradient(90deg, #fef08a, #fbbf24); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">produits</span>
                </span>
                d'exception
            </h1>
            
            <p class="text-lg md:text-xl text-white/80 mb-10 max-w-xl leading-relaxed">
                Une sélection premium de produits numériques et physiques, livrés avec soin et passion.
            </p>
            
            <div class="flex flex-wrap gap-4">
                <a href="{{ path('app_storefront_catalog') }}" class="group inline-flex items-center px-8 py-4 bg-white text-purple-700 font-bold rounded-2xl shadow-2xl shadow-purple-900/20 hover:shadow-purple-900/40 transition-all duration-300 hover:-translate-y-1">
                    <span>Explorer le catalogue</span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                </a>
                {% if not app.user %}
                <a href="{{ path('app_register') }}" class="inline-flex items-center px-8 py-4 bg-white/10 backdrop-blur-sm text-white font-bold rounded-2xl border-2 border-white/30 hover:bg-white/20 hover:border-white/50 transition-all duration-300">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                    </svg>
                    Créer un compte
                </a>
                {% endif %}
            </div>
        </div>
    </div>
    
    <!-- Decorative shapes -->
    <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-slate-50 dark:from-slate-900 to-transparent"></div>
</div>

<!-- Stats bar -->
<div class="flex flex-row gap-4 mb-16 -mt-8 relative z-20">
    <div class="flex-1 bg-white dark:bg-slate-800 rounded-2xl shadow-lg shadow-slate-200/50 dark:shadow-none p-6 text-center border border-slate-100 dark:border-slate-700">
        <div class="text-3xl font-black text-indigo-600 dark:text-indigo-400 mb-1">{{ products|length }}+</div>
        <div class="text-sm text-slate-500 dark:text-slate-400 font-medium">Produits</div>
    </div>
    <div class="flex-1 bg-white dark:bg-slate-800 rounded-2xl shadow-lg shadow-slate-200/50 dark:shadow-none p-6 text-center border border-slate-100 dark:border-slate-700">
        <div class="text-3xl font-black text-emerald-600 dark:text-emerald-400 mb-1">24h</div>
        <div class="text-sm text-slate-500 dark:text-slate-400 font-medium">Livraison</div>
    </div>
    <div class="flex-1 bg-white dark:bg-slate-800 rounded-2xl shadow-lg shadow-slate-200/50 dark:shadow-none p-6 text-center border border-slate-100 dark:border-slate-700">
        <div class="text-3xl font-black text-amber-500 dark:text-amber-400 mb-1">5★</div>
        <div class="text-sm text-slate-500 dark:text-slate-400 font-medium">Service</div>
    </div>
</div>

<!-- Featured Products -->
<section class="mb-20">
    <div class="flex flex-col md:flex-row md:justify-between md:items-end gap-4 mb-10">
        <div>
            <span class="inline-block px-3 py-1 bg-indigo-100 dark:bg-indigo-900/50 text-indigo-700 dark:text-indigo-300 rounded-lg text-sm font-semibold mb-3">🔥 Populaire</span>
            <h2 class="text-3xl md:text-4xl font-black text-slate-800 dark:text-white">Nos produits</h2>
        </div>
        <a href="{{ path('app_storefront_catalog') }}" class="inline-flex items-center text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 font-semibold group">
            Voir le catalogue complet
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
        </a>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        {% for product in products %}
            <a href="{{ path('app_storefront_product', {'slug': product.slug}) }}" 
               class="group bg-white dark:bg-slate-800 rounded-3xl p-4 shadow-sm hover:shadow-2xl transition-all duration-500 border border-slate-100 dark:border-slate-700 hover:-translate-y-2">
                
                <!-- Product Image -->
                <div class="relative aspect-square rounded-2xl overflow-hidden mb-4">
                    {% if product.imageFilename %}
                        <img src="{{ product.imagePath }}" alt="{{ product.name }}" class="w-full h-full object-cover">
                    {% else %}
                        <div class="absolute inset-0 {{ product.type == 'digital' ? 'bg-gradient-to-br from-violet-400 via-purple-500 to-fuchsia-500' : 'bg-gradient-to-br from-slate-100 via-slate-50 to-white dark:from-slate-700 dark:via-slate-600 dark:to-slate-700' }} flex items-center justify-center">
                            {% if product.type == 'digital' %}
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-white/80" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                </svg>
                            {% else %}
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-slate-300 dark:text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                                </svg>
                            {% endif %}
                        </div>
                    {% endif %}
                    
                    <!-- Type Badge -->
                    <div class="absolute top-3 left-3">
                        <span class="px-3 py-1.5 text-xs font-bold rounded-full {{ product.type == 'digital' ? 'bg-white/95 text-purple-700' : 'bg-indigo-600 text-white' }} shadow-sm">
                            {{ product.type == 'digital' ? '💾 Digital' : '📦 Physique' }}
                        </span>
                    </div>
                    
                    <!-- Hover CTA -->
                    <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-all duration-300 flex items-center justify-center">
                        <span class="opacity-0 group-hover:opacity-100 transition-all duration-300 px-4 py-2 bg-white rounded-xl font-bold text-slate-800 shadow-xl transform scale-75 group-hover:scale-100">
                            Voir →
                        </span>
                    </div>
                </div>
                
                <!-- Product Info -->
                <div>
                    <h3 class="font-bold text-slate-800 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors mb-2 line-clamp-1">
                        {{ product.name }}
                    </h3>
                    
                    <div class="flex items-center justify-between">
                        <div class="text-xl font-black text-indigo-600 dark:text-indigo-400">
                            {{ (product.price / 100)|number_format(2, ',', ' ') }}<span class="text-base"> €</span>
                        </div>
                        
                        {% if product.stock > 0 %}
                            <span class="w-3 h-3 bg-emerald-500 rounded-full ring-4 ring-emerald-500/20" title="En stock"></span>
                        {% else %}
                            <span class="w-3 h-3 bg-red-500 rounded-full ring-4 ring-red-500/20" title="Rupture"></span>
                        {% endif %}
                    </div>
                </div>
            </a>
        {% else %}
            <div class="col-span-full text-center py-20 bg-slate-50 dark:bg-slate-800 rounded-3xl">
                <div class="text-6xl mb-4">📦</div>
                <h3 class="text-xl font-bold text-slate-800 dark:text-white mb-2">Aucun produit</h3>
                <p class="text-slate-500 dark:text-slate-400">Revenez bientôt !</p>
            </div>
        {% endfor %}
    </div>
</section>

<!-- CTA Banner -->
<section class="relative overflow-hidden rounded-3xl bg-gradient-to-r from-slate-900 to-slate-800 text-white p-10 md:p-16 mb-16">
    <div class="relative z-10 max-w-2xl">
        <h2 class="text-3xl md:text-4xl font-black mb-4">Prêt à commander ?</h2>
        <p class="text-slate-300 text-lg mb-8">Inscrivez-vous maintenant et profitez de nos offres exclusives.</p>
        <a href="{{ path('app_register') }}" class="inline-flex items-center px-8 py-4 bg-white text-slate-900 font-bold rounded-2xl hover:bg-slate-100 transition-colors">
            Commencer maintenant
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
        </a>
    </div>
    <div class="absolute -right-20 -bottom-20 w-80 h-80 bg-indigo-600/20 rounded-full blur-3xl"></div>
    <div class="absolute right-1/4 -top-20 w-64 h-64 bg-purple-600/20 rounded-full blur-3xl"></div>
</section>

<!-- Features -->
<section class="grid grid-cols-1 md:grid-cols-3 gap-8">
    <div class="text-center p-8 bg-white dark:bg-slate-800 rounded-2xl border border-slate-100 dark:border-slate-700">
        <div class="w-16 h-16 bg-emerald-100 dark:bg-emerald-900/30 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-emerald-600 dark:text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </div>
        <h3 class="font-bold text-slate-800 dark:text-white text-lg mb-2">Qualité Premium</h3>
        <p class="text-slate-500 dark:text-slate-400">Tous nos produits sont rigoureusement sélectionnés.</p>
    </div>
    
    <div class="text-center p-8 bg-white dark:bg-slate-800 rounded-2xl border border-slate-100 dark:border-slate-700">
        <div class="w-16 h-16 bg-blue-100 dark:bg-blue-900/30 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
        </div>
        <h3 class="font-bold text-slate-800 dark:text-white text-lg mb-2">Livraison Express</h3>
        <p class="text-slate-500 dark:text-slate-400">Expédition en 24h pour tous vos achats.</p>
    </div>
    
    <div class="text-center p-8 bg-white dark:bg-slate-800 rounded-2xl border border-slate-100 dark:border-slate-700">
        <div class="w-16 h-16 bg-amber-100 dark:bg-amber-900/30 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-amber-600 dark:text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
        </div>
        <h3 class="font-bold text-slate-800 dark:text-white text-lg mb-2">Satisfaction Garantie</h3>
        <p class="text-slate-500 dark:text-slate-400">Satisfait ou remboursé, sans condition.</p>
    </div>
</section>
{% endblock %}
